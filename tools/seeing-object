#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from hub.ecology import EcologicalAgent
from hub.presence import PresenceDetector
from hub.scheduler import RoomBrain


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="seeing-object",
        description="Run the ecological behavior loop with audio presence detection.",
    )
    parser.add_argument("node_id", help="Node ID to drive, e.g. CAN_01")
    parser.add_argument("--root", default=None, help="Project root (defaults to this checkout)")
    parser.add_argument("--audio-device", default="hw:1,0", help="ALSA device for arecord (default hw:1,0 = M-Track)")
    parser.add_argument("--delta-db", type=float, default=10.0, help="How far above the rolling ambient floor counts as presence (default 10 dB)")
    parser.add_argument("--peak-hour", type=float, default=14.0, help="Circadian peak hour (default 14.0)")
    parser.add_argument("--circadian-min", type=float, default=0.7, help="Tap-rate multiplier at trough (default 0.7)")
    parser.add_argument("--circadian-max", type=float, default=2.5, help="Tap-rate multiplier at peak (default 2.5)")
    parser.add_argument("--tick-seconds", type=float, default=None, help="Override base tick interval")
    parser.add_argument("--max-ticks", type=int, default=None, help="Stop after N ticks (default: run forever)")
    args = parser.parse_args()

    brain = RoomBrain(args.root)
    presence = PresenceDetector(device=args.audio_device)
    agent = EcologicalAgent(
        brain=brain,
        node_id=args.node_id,
        presence=presence,
        delta_db_baseline=args.delta_db,
        delta_db=args.delta_db,
        circadian_peak_hour=args.peak_hour,
        circadian_min_multiplier=args.circadian_min,
        circadian_max_multiplier=args.circadian_max,
    )
    if args.tick_seconds is not None:
        agent.tick_seconds = args.tick_seconds
    agent.run(max_ticks=args.max_ticks)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
